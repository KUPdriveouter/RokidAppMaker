<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/solid_black">

    <!-- Header: Title + Edit badge -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:fontFamily="monospace"
            android:textColor="@color/hud_cyan_dim"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvDepth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:fontFamily="monospace"
            android:textColor="@color/hud_cyan"
            android:textSize="10sp" />
    </FrameLayout>

    <!-- Settings menu (takes remaining space above hint) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp">

        <!-- SYSTEM -->
        <TextView android:id="@+id/tvSection0"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textColor="@color/hud_cyan_dim"
            android:textSize="8sp" android:text="SYSTEM" android:letterSpacing="0.15"
            android:paddingBottom="2dp" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_cyan_dim" android:alpha="0.5" />

        <!-- Row 0 -->
        <LinearLayout android:id="@+id/row0"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel0"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue0"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_green_dim" android:alpha="0.15" />

        <!-- Row 1 -->
        <LinearLayout android:id="@+id/row1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel1"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>

        <!-- SENSITIVITY -->
        <TextView android:id="@+id/tvSection1"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textColor="@color/hud_cyan_dim"
            android:textSize="8sp" android:text="SENSITIVITY" android:letterSpacing="0.15"
            android:paddingTop="5dp" android:paddingBottom="2dp" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_cyan_dim" android:alpha="0.5" />

        <!-- Row 2 -->
        <LinearLayout android:id="@+id/row2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue2"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_green_dim" android:alpha="0.15" />

        <!-- Row 3 -->
        <LinearLayout android:id="@+id/row3"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel3"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue3"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>

        <!-- DWELL CLICK -->
        <TextView android:id="@+id/tvSection2"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textColor="@color/hud_cyan_dim"
            android:textSize="8sp" android:text="DWELL CLICK" android:letterSpacing="0.15"
            android:paddingTop="5dp" android:paddingBottom="2dp" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_cyan_dim" android:alpha="0.5" />

        <!-- Row 4 -->
        <LinearLayout android:id="@+id/row4"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel4"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue4"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_green_dim" android:alpha="0.15" />

        <!-- Row 5 -->
        <LinearLayout android:id="@+id/row5"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel5"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue5"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_green_dim" android:alpha="0.15" />

        <!-- Row 6 -->
        <LinearLayout android:id="@+id/row6"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel6"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue6"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>

        <!-- GESTURES -->
        <TextView android:id="@+id/tvSection3"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textColor="@color/hud_cyan_dim"
            android:textSize="8sp" android:text="GESTURES" android:letterSpacing="0.15"
            android:paddingTop="5dp" android:paddingBottom="2dp" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_cyan_dim" android:alpha="0.5" />

        <!-- Row 7 -->
        <LinearLayout android:id="@+id/row7"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="2dp" android:paddingBottom="2dp"
            android:paddingStart="6dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvLabel7"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:fontFamily="monospace"
                android:textSize="12sp" android:letterSpacing="0.03" />
            <TextView android:id="@+id/tvValue7"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/hud_green_dim" android:alpha="0.15" />

        <!-- Row 8 (hidden, kept for binding compatibility) -->
        <LinearLayout android:id="@+id/row8"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:visibility="gone"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvLabel8"
                android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvValue8"
                android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>

        <!-- Hidden rows (binding compatibility) -->
        <TextView android:id="@+id/tvLabel9" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvValue9" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvLabel10" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tvValue10" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>

    <!-- Controls guide (fixed at bottom) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hud_cyan_dim"
        android:alpha="0.3"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/hud_green_dim"
        android:textSize="10sp"
        android:lineSpacingExtra="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

</LinearLayout>
