<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Rokid Glasses HUD theme:
        - Pure black background (transparent on waveguide)
        - No title bar, no status bar, full immersive
        - Optimized for green monochrome Micro LED
    -->
    <style name="RidiGlassTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:colorBackground">#000000</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
</resources>
